{
  "name": "picgo-upload-layer",
  "version": "0.1.0",
  "description": "基于 libc 架构理念重构的 PicGo 上传图层。统一上下文 UploadCtx + 声明式接口头文件 upload_ctx.h.ts + 6 步标准流水线 + 独立可插拔的图床模块，为图片上传提供一套类型可靠、结构清晰、易于扩展的底层框架。",
  "private": true,
  "type": "module",
  "main": "dist/upload/index.js",
  "types": "dist/upload/index.d.ts",
  "bin": {
    "picgo-upload-layer": "bin/picgo-upload-layer.js",
    "picgo-ul": "bin/picgo-upload-layer.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "test": "node --loader tsx test/integration.test.ts",
    "clean": "rm -rf dist",
    "upload": "node --loader tsx src/upload/cli.ts upload",
    "picgo-list": "node --loader tsx src/upload/cli.ts list",
    "picgo-stats": "node --loader tsx src/upload/cli.ts stats",
    "picgo-health": "node --loader tsx src/upload/cli.ts health",
    "picgo-init-config": "node --loader tsx src/upload/cli.ts init-config"
  },
  "keywords": [
    "picgo",
    "image-upload",
    "image-hosting",
    "image-host",
    "smms",
    "github-upload",
    "typescript",
    "libc-architecture",
    "ai-tp-os",
    "pipeline",
    "modular",
    "uploader",
    "markdown-image",
    "electron"
  ],
  "author": "ghshhf",
  "contributors": [
    "picgo-upload-layer"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ghshhf/PicGo.git"
  },
  "homepage": "https://github.com/ghshhf/PicGo",
  "bugs": {
    "url": "https://github.com/ghshhf/PicGo/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
